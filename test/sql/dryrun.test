# name: test/sql/dryrun.test
# description: test dryrun extension
# group: [sql]

require parquet

require dryrun

statement ok
COPY (
	SELECT
		i::INTEGER AS i,
		(i % 10)::INTEGER AS bucket,
		'payload_' || i::VARCHAR AS payload
	FROM range(0, 4096) t(i)
) TO '{TEMP_DIR}/dryrun_events.parquet' (FORMAT PARQUET, ROW_GROUP_SIZE 2048);

statement ok
COPY (
	SELECT i::INTEGER AS i, 'a_' || i::VARCHAR AS payload
	FROM range(0, 128) t(i)
) TO '{TEMP_DIR}/dryrun_events_a.parquet' (FORMAT PARQUET);

statement ok
COPY (
	SELECT i::INTEGER AS i, 'b_' || i::VARCHAR AS payload
	FROM range(128, 256) t(i)
) TO '{TEMP_DIR}/dryrun_events_b.parquet' (FORMAT PARQUET);

# One local Parquet file, SELECT *.
query IIIIIIITI
SELECT
	estimated_compute_bytes > 0,
	estimated_compute_bytes = estimated_compressed_bytes,
	estimated_uncompressed_bytes > 0,
	estimated_metadata_bytes > 0,
	estimated_files,
	estimated_row_groups,
	total_row_groups,
	confidence,
	notes LIKE '%estimated_compute_bytes equals estimated_compressed_bytes%'
FROM dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet''');
----
true	true	true	true	1	2	2	high	true

# Projected columns should estimate fewer bytes than SELECT *.
query I
SELECT projected.estimated_compressed_bytes < full_scan.estimated_compressed_bytes
FROM dryrun('SELECT i FROM ''{TEMP_DIR}/dryrun_events.parquet''') projected,
     dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet''') full_scan;
----
true

# COUNT(*) over a join still has to read the join key columns.
query III
WITH estimate AS (
	SELECT *
	FROM dryrun('SELECT count(*) FROM ''{TEMP_DIR}/dryrun_events_a.parquet'' a LEFT JOIN ''{TEMP_DIR}/dryrun_events_b.parquet'' b ON a.i = b.i')
), metadata AS (
	SELECT sum(total_compressed_size) AS compressed_bytes
	FROM (
		SELECT total_compressed_size
		FROM parquet_metadata('{TEMP_DIR}/dryrun_events_a.parquet')
		WHERE path_in_schema = 'i'
		UNION ALL
		SELECT total_compressed_size
		FROM parquet_metadata('{TEMP_DIR}/dryrun_events_b.parquet')
		WHERE path_in_schema = 'i'
	)
)
SELECT
	estimate.estimated_compressed_bytes = metadata.compressed_bytes,
	estimate.estimated_compressed_bytes > 0,
	estimate.confidence
FROM estimate, metadata;
----
true	true	low

# Multiple Parquet files via glob.
query II
SELECT estimated_files, estimated_row_groups >= 2
FROM dryrun('SELECT * FROM read_parquet(''{TEMP_DIR}/dryrun_events_*.parquet'')');
----
2	true

# Generic HTTP/HTTPS does not provide file listing for glob expansion.
statement error
SELECT * FROM dryrun('SELECT * FROM ''https://dryrun-data.dahl.dev/yellow_tripdata_2022-0*.parquet''');
----
Binder Error: dryrun does not support HTTP/HTTPS globbing; use explicit file URLs or read_parquet([...])

# Simple filter should prune at least one row group.
query IIT
SELECT
	filtered.estimated_row_groups < full_scan.estimated_row_groups,
	filtered.total_row_groups = full_scan.total_row_groups,
	filtered.confidence
FROM dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet'' WHERE i < 10') filtered,
     dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet''') full_scan;
----
true	true	medium

# Complex filters fall back without executing the target query expression.
query IT
SELECT notes LIKE '%filter not analyzable%', confidence
FROM dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet'' WHERE i = CAST(''not-an-int'' AS INTEGER)');
----
true	low

# CSV/JSON are rejected clearly.
statement error
SELECT * FROM dryrun('SELECT * FROM ''{TEMP_DIR}/events.csv''');
----
Binder Error: dryrun only supports Parquet scans in v1

# Non-SELECT queries are rejected.
statement error
SELECT * FROM dryrun('CREATE TABLE x(i INTEGER)');
----
Binder Error: dryrun only supports read-only SELECT queries

# Multiple statements are rejected.
statement error
SELECT * FROM dryrun('SELECT * FROM ''{TEMP_DIR}/dryrun_events.parquet''; SELECT 1');
----
Binder Error: dryrun only supports exactly one SQL statement
